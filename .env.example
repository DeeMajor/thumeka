# ────────────────────────────────────────────────────────────────────────────
# REQUIRED — the app will not boot without these
# ────────────────────────────────────────────────────────────────────────────

# Browser + server endpoint. `npx supabase start` prints these for local dev.
NEXT_PUBLIC_SUPABASE_URL=
# Browser-exposed anon key (RLS-restricted, safe to expose).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only admin key. NEVER expose this to the browser. The `lib/supabase/admin.ts`
# helper is `import "server-only"`-gated so a stray client import will fail build.
SUPABASE_SERVICE_ROLE_KEY=

# Base URL used for email links, OG tags, and Sentry release tracking.
# In production set to your real domain. In local dev: http://127.0.0.1:3000
NEXT_PUBLIC_APP_URL=https://mercury.hkdns.host

# ────────────────────────────────────────────────────────────────────────────
# OPTIONAL — features degrade gracefully if unset
# ────────────────────────────────────────────────────────────────────────────

# WhatsApp Support — international format, no spaces or +. Surfaced on /support.
NEXT_PUBLIC_SUPPORT_WHATSAPP_NUMBER=

# Resend transactional email.
# When RESEND_API_KEY is unset, sendEmail() is a no-op and flows still complete.
# EMAIL_FROM must be a verified domain in your Resend project.
# Defaults to "Thumeka <noreply@thumeka.co.za>" when unset.
EMAIL_FROM=
RESEND_API_KEY=

# Google Maps server-side: Geocoding API + Distance Matrix API enabled, billing on.
# When unset, checkout refuses orders it can't quote (no silent fallbacks in prod).
GOOGLE_MAPS_API_KEY=

# ────────────────────────────────────────────────────────────────────────────
# PAYFAST — payment gateway. All four required for "Pay now" to work.
# ────────────────────────────────────────────────────────────────────────────

# Default mode is "sandbox" — fails closed against real money if the env var
# is unset or typo'd. Set to "production" once you've signed off on the
# sandbox end-to-end. PayFast's URLs are:
#   sandbox    →  https://sandbox.payfast.co.za/eng/process
#   production →  https://www.payfast.co.za/eng/process
PAYFAST_MODE=sandbox

# Sandbox test credentials (publicly published by PayFast). Replace with
# your live merchant credentials before flipping PAYFAST_MODE=production.
#   sandbox merchant: https://sandbox.payfast.co.za
#   production: https://merchant.payfast.co.za
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a

# Passphrase — set on your merchant account. Required for signature
# verification on every ITN. Leave blank ONLY if your merchant account has
# no passphrase configured (not recommended; PayFast enables it by default).
PAYFAST_PASSPHRASE=jt7NOE43FZPn

# Google Maps browser-side: Places API enabled, HTTP-referrer-restricted to your
# domain. Powers address autocomplete on provider apply + checkout. When unset
# the inputs fall back to plain text + the server geocodes on submit.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ────────────────────────────────────────────────────────────────────────────
# OBSERVABILITY — Sentry. Configs are no-ops if unset.
# ────────────────────────────────────────────────────────────────────────────

# Browser + server runtime DSN. Set to enable error capture in production.
NEXT_PUBLIC_SENTRY_DSN=
# Optional: same DSN for server-only init (preferred if you don't want it bundled
# into the browser code).
SENTRY_DSN=
# Used in Sentry tags. Defaults to "production".
SENTRY_ENV=

# Source-map upload (build-time only). Without these, builds work but stack
# traces in Sentry show minified code.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ────────────────────────────────────────────────────────────────────────────
# DEV-ONLY — must NOT be set in production
# ────────────────────────────────────────────────────────────────────────────

# When set, lets checkout produce a deterministic quote without Google Maps.
# Used by tests + local-dev when Maps keys aren't configured. Any positive
# number works (km). Production must leave this unset so unquotable orders
# are rejected at checkout, not silently mis-priced.
# DELIVERY_FALLBACK_KM=4
